NODE_ENV=development
PORT=3000

# Turso — pruebas y producción usan bases en la nube; ambas requieren URL + token
# Crear/obtener con:
#   turso db create <nombre>
#   turso db show <nombre> --url
#   turso db tokens create <nombre>
DATABASE_URL=libsql://YOUR-DB.turso.io
DATABASE_AUTH_TOKEN=your-turso-auth-token

# Secrets — mínimo 32 caracteres, generados con: openssl rand -hex 32
ACCESS_TOKEN_SECRET=change_me_min_32_chars_long_secret_key_here
REFRESH_TOKEN_SECRET=change_me_another_32_chars_long_secret_key

# Expiry
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=30d

# CORS — separados por coma para múltiples orígenes
# Dev:
CORS_ORIGIN=http://localhost:5173
# Prod (ejemplo):
# CORS_ORIGIN=https://gastos.santiagomustafa.com.ar
